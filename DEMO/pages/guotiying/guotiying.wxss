.back-btn {
  position: fixed;
  left: 24rpx;
  top: 85rpx;
  z-index: 10;
}

.back-icon {
  font-size: 40rpx;
}

.setting-switch-wrapper {
  position: fixed;
  right: 24rpx;
  top: 85rpx;
  z-index: 10;
}

.switch-container {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.switch-label {
  color: #fff;
  font-size: 22rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.5);
}

.page {
  min-height: 100vh;
  position: relative;
}

.background-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.background-image {
  width: 100%;
  height: 100%;
}

.background-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.28);
}

.content {
  padding: 180rpx 32rpx 48rpx;
}

.title {
  text-align: center;
  font-size: 52rpx;
  color: #fff;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

.card {
  margin-top: 36rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 22rpx;
  padding: 26rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.16);
}

.card-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1f2937;
}

.section-label {
  margin-top: 20rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #374151;
  font-weight: 700;
}

.suit-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suit-item {
  padding: 10rpx 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d1d5db;
  color: #374151;
  font-size: 24rpx;
  background: #f9fafb;
}

.suit-item.active {
  border-color: #4f46e5;
  background: #eef2ff;
  color: #3730a3;
  font-weight: 700;
}

.point-input {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d1d5db;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
  color: #111827;
  background: #fff;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
}

.action-btn {
  flex: 1;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.action-btn.primary {
  background: #4f46e5;
  color: #fff;
}

.empty-tip {
  color: #6b7280;
  font-size: 24rpx;
  padding: 8rpx 0;
}

.record-list {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-item {
  background: #f3f4f6;
  color: #1f2937;
  border-radius: 12rpx;
  padding: 10rpx 14rpx;
  font-size: 24rpx;
}