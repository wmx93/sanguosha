/* pages/caojinyu/caojinyu.wxss */

/* 顶部开关样式 */
.setting-switch-wrapper {
  position: fixed;
  right: 24rpx;
  top: 85rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  pointer-events: auto;
}

.switch-container {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  padding: 6rpx 12rpx 6rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.switch-label {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.switch-container switch {
  transform: scale(0.7);
  margin-right: -10rpx;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  position: relative;
}

/* 背景图片层 */
.background-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.content-wrapper {
  width: 100%;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-title {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 60rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 标签组样式 */
.label-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

.label-item {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(12rpx);
  padding: 30rpx 40rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.label-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.label-value {
  color: #667eea;
  font-size: 44rpx;
  font-weight: 800;
  background: #fff;
  padding: 4rpx 20rpx;
  border-radius: 12rpx;
  margin: 0 16rpx;
  min-width: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 操作按钮样式 */
.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  max-width: 500rpx;
}

.undo-btn {
  width: 100%;
  height: 100rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 80ms ease;
  margin-top: 10rpx;
}

.action-btn {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #667eea;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 80ms ease, box-shadow 80ms ease;
}

/* 按压反馈：略微缩小即可 */
.btn-press {
  transform: scale(0.97);
}

.reset-btn {
  margin-top: 20rpx;
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 返回按钮样式 */
.back-btn {
  position: fixed;
  top: 85rpx;
  left: 24rpx;
  z-index: 10;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  color: #fff;
  background: transparent;
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn::after {
  border: none;
}

.back-icon {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
  transform: translateX(-2rpx);
}
