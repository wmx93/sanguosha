/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
  position: relative;
}

/* 背景图片层 */
.background-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 背景遮罩层，用于提高文字可读性 */
.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1;
}

.container {
  padding: 40rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 60rpx;
  text-align: center;
}

.button-container {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 60rpx;
}

.draw-btn {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #667eea;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.draw-btn::after {
  border: none;
}

.result-container {
  width: 100%;
  max-width: 600rpx;
  animation: fadeIn 0.5s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.skill-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.skill-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #667eea;
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.skill-description {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  text-align: center;
  white-space: pre-line;
}

/* .skill-description.placeholder 已移除，使用统一样式 */

.hint {
  margin-top: 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
}

.back-btn {
  position: fixed;
  top: 20rpx;
  left: 20rpx;
  z-index: 10;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  color: #fff;
  background: transparent;
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn::after {
  border: none;
}

.back-icon {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
  transform: translateX(-2rpx);
}