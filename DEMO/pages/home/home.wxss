/* 清爽白底 + 蓝色点缀 */

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 0;
  box-sizing: border-box;
  background: #f8fafc;
  color: #1a202c;
}

/* 品牌头部 */
.brand-header {
  padding: 20rpx 0 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
  border-radius: 20rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #007AFF 0%, #4A90E2 100%);
  color: white;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.25);
}

.brand-info {
  flex: 1;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a202c;
  letter-spacing: 0.5rpx;
}

.brand-tagline {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 600;
}

.header-actions {
  margin-top: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(0, 122, 255, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  color: #007AFF;
  font-size: 28rpx;
}

.search-placeholder {
  color: #64748b;
  font-size: 26rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1a202c;
}

/* 轮播 */
.banner-section {
  margin-top: 20rpx;
}

.banner-swiper {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.banner-item {
  position: relative;
  height: 280rpx;
  background: linear-gradient(135deg, #007AFF 0%, #4A90E2 100%);
}

.banner-image {
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 24rpx 20rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
}

.banner-title {
  font-size: 32rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a202c;
}

/* 快捷入口 */
.quick-entries {
  margin-top: 28rpx;
}

.entries-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  column-gap: 16rpx;
  row-gap: 16rpx;
}

.entry-item {
  flex: 0 0 160rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: white;
  border: 2rpx solid rgba(0, 122, 255, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.entry-item:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.2);
  border-color: rgba(0, 122, 255, 0.3);
}

.entry-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #007AFF 0%, #4A90E2 100%);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.25);
  overflow: hidden;
}

.entry-icon-img {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.entry-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #374151;
  font-weight: 600;
  text-align: center;
}

.all-generals-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 76rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #007AFF;
  background: #ffffff;
  border: 2rpx solid rgba(0, 122, 255, 0.2);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.all-generals-btn::after {
  border: none;
}

.tool-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.tool-btn {
  width: 330rpx;
  height: 330rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #1688FF 0%, #3BA0FF 50%, #69B8FF 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(0, 122, 255, 0.28);
}

.tool-btn:active {
  transform: scale(0.98);
  opacity: 0.92;
}

/* 底部留白 */
.bottom-spacer {
  height: 60rpx;
}

/* swiper 指示点适配 */
wx-swiper .wx-swiper-dots,
.swiper-dots {
  bottom: 16rpx;
}

wx-swiper .wx-swiper-dot {
  background: rgba(255, 255, 255, 0.6);
  width: 8rpx;
  height: 8rpx;
}

wx-swiper .wx-swiper-dot-active {
  background: #ffffff;
  width: 20rpx;
  height: 8rpx;
  border-radius: 4rpx;
}