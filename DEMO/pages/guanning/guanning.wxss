/* pages/guanning/guanning.wxss */
.container {
  padding: 20px;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 主要按钮样式 */
.button-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  justify-content: center;
  margin-bottom: 30px;
}

.main-button {
  width: 120px;
  height: 120px;
  border-radius: 15px;
  border: 2px solid #ddd;
  background-color: #fff;
  color: #333;
  font-size: 24px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.main-button:active {
  transform: scale(0.95);
}

.main-button.clicked {
  background-color: #007aff;
  color: white;
  border-color: #007aff;
  box-shadow: 0 4px 12px rgba(0, 122, 255, 0.3);
}

/* 第二个按钮组样式 */
.secondary-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.secondary-buttons {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  justify-content: center;
}

.secondary-button {
  min-width: 100px;
  height: 50px;
  border-radius: 10px;
  border: 1px solid #007aff;
  background-color: #007aff;
  color: white;
  font-size: 16px;
  padding: 0 15px;
  transition: all 0.2s ease;
}

.secondary-button:active {
  background-color: #0056cc;
  transform: scale(0.95);
}

/* 技能选择区域 */
.skill-selection {
  width: 100%;
  max-width: 400px;
  background-color: white;
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
}

.skill-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15px;
  text-align: center;
}

.skill-buttons {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.skill-button {
  height: 50px;
  border-radius: 8px;
  border: 1px solid #007aff;
  background-color: white;
  color: #007aff;
  font-size: 16px;
  padding: 0 15px;
  text-align: left;
  transition: all 0.2s ease;
  word-wrap: break-word;
  white-space: normal;
}

.skill-button:active {
  background-color: #f0f8ff;
  transform: scale(0.98);
}

/* 删除确认对话框 */
.delete-confirm {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.confirm-dialog {
  background-color: white;
  border-radius: 15px;
  padding: 30px;
  width: 300px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

.confirm-dialog text {
  font-size: 16px;
  color: #333;
  display: block;
  margin-bottom: 20px;
}

.confirm-buttons {
  display: flex;
  gap: 15px;
  justify-content: center;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 45px;
  border-radius: 8px;
  border: none;
  font-size: 16px;
  font-weight: bold;
  transition: all 0.2s ease;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background-color: #e5e5e5;
}

.confirm-btn {
  background-color: #ff3b30;
  color: white;
}

.confirm-btn:active {
  background-color: #d63027;
}