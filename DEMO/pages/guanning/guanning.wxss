/* pages/guanning/guanning.wxss */
.container {
  padding: 20px;
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 背景图片层 */
.background-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
}

/* 主要按钮样式 */
.button-container {
  display: flex;
  flex-wrap: wrap;
  width: 280px;
  gap: 20px;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.main-button {
  width: 50px;
  height: 50px;
  border-radius: 20px;
  border: none;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  color: #667eea;
  font-size: 28px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15),
              0 2px 6px rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.main-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.main-button:active {
  transform: scale(0.95) translateY(2px);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2),
              0 1px 3px rgba(0, 0, 0, 0.15);
}

.main-button:active::before {
  opacity: 1;
}

.main-button.clicked {
  background: linear-gradient(135deg, #007aff 0%, #0051d5 100%);
  color: white;
  box-shadow: 0 12px 30px rgba(0, 122, 255, 0.4),
              0 4px 12px rgba(0, 122, 255, 0.3);
  transform: translateY(-2px);
}

.main-button.clicked::before {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0) 100%);
  opacity: 1;
}

/* 第二个按钮组样式 */
.secondary-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
  position: relative;
  z-index: 1;
  margin-top: 30px;
  width: 100%;
}

.secondary-buttons {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  justify-content: center;
}

.secondary-button {
  min-width: 100px;
  height: 50px;
  border-radius: 10px;
  border: 1px solid #007aff;
  background-color: #007aff;
  color: white;
  font-size: 16px;
  padding: 0 15px;
  transition: all 0.2s ease;
}

.secondary-button:active {
  background-color: #0056cc;
  transform: scale(0.95);
}

.acquired-skill-list {
  width: 100%;
  max-width: 400px;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 15px;
  padding: 15px;
  box-shadow: 0 1px 8px rgba(0, 0, 0, 0.08);
  margin-top: 20px;
}

/* 技能选择区域 */
.skill-selection {
  width: 100%;
  max-width: 400px;
  background-color: white;
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.skill-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15px;
  text-align: center;
}

.skill-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.skill-button {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50px;
  border-radius: 8px;
  border: 1px solid #007aff;
  background-color: white;
  color: #007aff;
  font-size: 16px;
  padding: 0 15px;
  text-align: left;
  transition: all 0.2s ease;
  word-wrap: break-word;
  white-space: normal;
}

.skill-button:active {
  background-color: #f0f8ff;
  transform: scale(0.98);
}

/* 删除确认对话框 */
.delete-confirm {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.confirm-dialog {
  background-color: white;
  border-radius: 15px;
  padding: 30px;
  width: 300px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

.confirm-dialog text {
  font-size: 16px;
  color: #333;
  display: block;
  margin-bottom: 20px;
}

.confirm-buttons {
  display: flex;
  gap: 15px;
  justify-content: center;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 45px;
  border-radius: 8px;
  border: none;
  font-size: 16px;
  font-weight: bold;
  transition: all 0.2s ease;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background-color: #e5e5e5;
}

.confirm-btn {
  background-color: #ff3b30;
  color: white;
}

.confirm-btn:active {
  background-color: #d63027;
}

/* 返回按钮样式 */
.back-btn {
  position: fixed;
  top: 20rpx;
  left: 20rpx;
  z-index: 10;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  color: #fff;
  background: transparent;
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn::after {
  border: none;
}

.back-icon {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
  transform: translateX(-2rpx);
}