<!--pages/guanning/guanning.wxml-->
<button class="back-btn" plain type="default" size="mini" bindtap="goBack" aria-label="返回" style="position: fixed; left: 24rpx; top: 85rpx">
  <text class="back-icon">‹</text>
</button>

<!-- 动态背景切换开关 -->
<view class="setting-switch-wrapper" style="position: fixed; right: 24rpx; top: 85rpx; z-index: 100;">
  <view class="switch-container" style="position: relative; left: 0rpx; top: 100rpx">
    <text class="switch-label">动图背景</text>
    <switch checked="{{useGifBackground}}" bindchange="toggleGifBackground" color="#667eea" scale="0.8" />
  </view>
</view>

<view class="container">
  <!-- 背景图片层：开启时显示动图，关闭时显示静态图 -->
  <view class="background-layer" wx:if="{{(useGifBackground && gifBackgroundImage) || (!useGifBackground && staticBackgroundImage)}}">
    <image
      class="background-image"
      src="{{useGifBackground ? gifBackgroundImage : staticBackgroundImage}}"
      mode="aspectFill"
    ></image>
    <view class="background-overlay"></view>
  </view>
  
  <!-- 初始四个按钮 -->
  <view class="button-container">
    <button
      wx:for="{{mainButtons}}"
      wx:key="id"
      class="main-button {{item.clicked ? 'clicked' : ''}}"
      bindtap="onMainButtonTap"
      data-id="{{item.id}}"
    >
      {{item.text}}
    </button>
  </view>

  <!-- 第二次点击后显示的三个按钮 -->
  <view class="secondary-container" wx:if="{{showSecondaryButtons}}">
    <view class="secondary-buttons">
      <button
        wx:for="{{secondaryButtons}}"
        wx:key="id"
        class="secondary-button"
        bindtap="onSecondaryButtonTap"
        data-id="{{item.id}}"
      >
        {{item.text}}
      </button>
    </view>

    <!-- 技能选择区域 -->
    <view class="skill-selection" wx:if="{{showSkills}}">
      <text class="skill-title">防止此伤害，选择1个包含“仁义礼智信”的技能令其获得：</text>
      <view class="skill-buttons">
        <button
          wx:for="{{skillButtons}}"
          wx:key="id"
          class="skill-button"
          bindtap="onSkillButtonTap"
          data-skill="{{item.skill}}"
        >
          {{item.skill.name}}
        </button>
      </view>
    </view>
  </view>

  <!-- 已获得技能列表 -->
  <view class="acquired-skill-list" wx:if="{{acquiredSkills.length}}">
    <text class="skill-title">已获得技能：</text>
    <view class="skill-buttons">
      <button
        wx:for="{{acquiredSkills}}"
        wx:key="name"
        class="skill-button acquired"
        bindtap="onAcquiredSkillTap"
        data-skill="{{item}}"
      >
        {{item.name}}
      </button>
    </view>
  </view>

</view>
