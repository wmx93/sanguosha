/* pages/shenjiangwei/shenjiangwei.wxss */
.back-btn {
  position: fixed;
  left: 24rpx;
  top: 85rpx;
  z-index: 100;
}

.back-icon {
  font-size: 40rpx;
}

.setting-switch-wrapper {
  position: fixed;
  right: 24rpx;
  top: 85rpx;
  z-index: 100;
}

.switch-container {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.switch-label {
  color: #fff;
  font-size: 22rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.5);
}

.scrollarea {
  height: 100vh;
}

.background-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.background-image {
  width: 100%;
  height: 100%;
}

.background-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.28);
}

.container {
  min-height: 100vh;
  padding: 180rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.title {
  text-align: center;
  font-size: 52rpx;
  color: #fff;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

.counter-card {
  margin-top: 28rpx;
  width: 100%;
  padding: 28rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 24rpx;
}

.counter-label {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.counter-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.count-btn {
  width: 96rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #667eea;
  font-size: 44rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn::after {
  border: none;
}

.count-number {
  min-width: 120rpx;
  text-align: center;
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
}

.counter-reset-btn {
  margin-top: 22rpx;
  width: 100% !important;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.counter-reset-btn::after {
  border: none;
}

.mark-card {
  margin-top: 24rpx;
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 24rpx;
}

.mark-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.mark-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.mark-reset-btn {
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(102, 126, 234, 0.9);
}

.mark-reset-btn::after {
  border: none;
}

.mark-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.mark-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #334155;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.mark-item.used {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.35);
}