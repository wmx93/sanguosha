.container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.background-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.background-image {
  width: 100%;
  height: 100%;
}

.background-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.25);
}

.back-btn {
  z-index: 10;
}

.back-icon {
  font-size: 40rpx;
}

.content {
  padding-top: 160rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  color: #fff;
}

.section {
  margin-bottom: 32rpx;
}

.general-section {
  margin-bottom: 16rpx;
}

.preview-section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  display: block;
}

.general-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
}

.general-item {
  width: 300rpx;
  height: 80rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.general-item.selected {
  background: #07c160;
  color: #fff;
  border-color: rgba(255, 255, 255, 0.4);
}

.general-name {
  font-size: 28rpx;
}

.skill-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-button {
  font-size: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.35);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.skill-item {
  padding: 6rpx 0;
}

.skill-text {
  font-size: 24rpx;
}

.confirm-btn {
  display: block !important;
  margin: 40rpx auto !important;
  width: 400rpx !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  padding: 0 !important;
  border-radius: 40rpx !important;
}

.reroll-btn {
  display: block !important;
  margin: 40rpx auto !important;
  width: 360rpx !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  padding: 0 !important;
  border-radius: 40rpx !important;
}

.preview-skill-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.preview-skill-item {
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.35);
}

.skill-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  opacity: 0.86;
}