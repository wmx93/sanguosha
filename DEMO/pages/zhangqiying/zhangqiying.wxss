.back-btn {
  position: fixed;
  left: 24rpx;
  top: 85rpx;
  z-index: 10;
}

.back-icon {
  font-size: 40rpx;
}

.setting-switch-wrapper {
  position: fixed;
  right: 24rpx;
  top: 85rpx;
  z-index: 10;
}

.switch-container {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  backdrop-filter: blur(8rpx);
}

.switch-label {
  color: #fff;
  font-size: 22rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.5);
}

.page {
  min-height: 100vh;
  position: relative;
}

.background-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.background-image {
  width: 100%;
  height: 100%;
}

.background-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.28);
}

.content {
  padding: 180rpx 32rpx 48rpx;
}

.title {
  text-align: center;
  font-size: 52rpx;
  color: #fff;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

.card {
  margin-top: 36rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 22rpx;
  padding: 26rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.16);
}

.card-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1f2937;
}

.card-desc {
  margin-top: 10rpx;
  color: #374151;
  font-size: 24rpx;
}

.suit-list {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.suit-btn {
  border-radius: 14rpx;
  font-size: 26rpx;
  background: #eef2ff;
  color: #3730a3;
  border: 1rpx solid #c7d2fe;
}

.record-header {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.clear-btn {
  background: #f3f4f6;
  color: #374151;
  border-radius: 10rpx;
  padding: 0 14rpx;
}

.record-box {
  margin-top: 12rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid #e5e7eb;
  min-height: 180rpx;
  padding: 14rpx;
}

.empty-tip {
  color: #6b7280;
  font-size: 24rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-item {
  font-size: 24rpx;
  color: #111827;
  background: #f9fafb;
  border-radius: 10rpx;
  padding: 8rpx 10rpx;
}
