<!-- pages/xvshao/xvshao.wxml -->
<button class="back-btn" plain type="default" size="mini" bindtap="goBack" aria-label="返回" style="position: fixed; left: 24rpx; top: 85rpx">
  <text class="back-icon">‹</text>
</button>
<view class="container">
  <!-- 预览小图背景（xvshao.png） -->
  <view class="background-layer" wx:if="{{backgroundPreview}}">
    <image class="background-image" src="{{backgroundPreview}}" mode="aspectFill"></image>
    <view class="background-overlay"></view>
  </view>

  <!-- 大图背景（xvshao3.png），加载出来后覆盖在上面 -->
  <view class="background-layer" wx:if="{{backgroundImage}}">
    <image class="background-image" src="{{backgroundImage}}" mode="aspectFill"></image>
    <view class="background-overlay"></view>
  </view>

  <view class="secondary-container">
    <view class="secondary-buttons">
      <button
        wx:for="{{phaseButtons}}"
        wx:key="id"
        class="secondary-button phase-button"
        bindtap="onPhaseTap"
        data-id="{{item.id}}"
      >
        {{item.text}}
      </button>
    </view>

    <!-- 候选技能：三选一获得 -->
    <view class="skill-selection" wx:if="{{drawnSkills.length}}">
      <text class="skill-title">选择一个技能：</text>
      <view class="skill-buttons">
        <button
          wx:for="{{drawnSkills}}"
          wx:key="name"
          class="skill-button phase-button"
          bindtap="onDrawnSkillTap"
          data-skill="{{item}}"
        >
          {{item.name}}
        </button>
      </view>
    </view>

    <!-- 已获得技能：点击查看描述 -->
    <view class="skill-selection" wx:if="{{obtainedSkills.length}}">
      <text class="skill-title">已获得技能（点击查看）：</text>
      <view class="skill-buttons">
        <button
          wx:for="{{obtainedSkills}}"
          wx:key="name"
          class="skill-button phase-button"
          bindtap="onObtainedSkillTap"
          data-skill="{{item}}"
        >
          {{item.name}}
        </button>
      </view>
    </view>
  </view>
</view>
