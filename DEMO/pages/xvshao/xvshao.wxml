<!-- pages/xvshao/xvshao.wxml -->
<button class="back-btn" plain type="default" size="mini" bindtap="goBack" aria-label="返回" style="position: fixed; left: 24rpx; top: 85rpx">
  <text class="back-icon">‹</text>
</button>

<!-- 动态背景切换开关 -->
<view class="setting-switch-wrapper" style="position: fixed; right: 24rpx; top: 85rpx; z-index: 100;">
  <view class="switch-container" style="position: relative; left: 0rpx; top: 100rpx">
    <text class="switch-label">动图背景</text>
    <switch checked="{{useGifBackground}}" bindchange="toggleGifBackground" color="#667eea" scale="0.8" />
  </view>
</view>

<view class="container">
  <!-- 背景图片层：开启时显示动图，关闭时显示静态图 -->
  <view class="background-layer" wx:if="{{(useGifBackground && gifBackgroundImage) || (!useGifBackground && staticBackgroundImage)}}">
    <image
      class="background-image"
      src="{{useGifBackground ? gifBackgroundImage : staticBackgroundImage}}"
      mode="aspectFill"
    ></image>
    <view class="background-overlay"></view>
  </view>

  <view class="secondary-container">
    <view class="secondary-buttons">
      <button
        wx:for="{{phaseButtons}}"
        wx:key="id"
        class="secondary-button phase-button"
        bindtap="onPhaseTap"
        data-id="{{item.id}}"
      >
        {{item.text}}
      </button>
    </view>

    <!-- 候选技能：三选一获得 -->
    <view class="skill-selection" wx:if="{{drawnSkills.length}}">
      <text class="skill-title">选择一个技能：</text>
      <view class="skill-buttons">
        <button
          wx:for="{{drawnSkills}}"
          wx:key="name"
          class="skill-button phase-button"
          bindtap="onDrawnSkillTap"
          data-skill="{{item}}"
        >
          {{item.name}}
        </button>
      </view>
    </view>

    <!-- 已获得技能：点击查看描述 -->
    <view class="skill-selection" wx:if="{{obtainedSkills.length}}">
      <text class="skill-title">已获得技能（点击查看）：</text>
      <view class="skill-buttons">
        <button
          wx:for="{{obtainedSkills}}"
          wx:key="name"
          class="skill-button phase-button"
          bindtap="onObtainedSkillTap"
          data-skill="{{item}}"
        >
          {{item.name}}
        </button>
      </view>
    </view>
  </view>
</view>
