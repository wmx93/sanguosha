@import "../guanning/guanning.wxss";

/* 复用 index 页面的 draw-btn 样式 */
.phase-button,
.secondary-button,
.skill-button {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #667eea;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.phase-button::after,
.secondary-button::after,
.skill-button::after {
  border: none;
}

/* 激活状态高亮 */
.secondary-button.active {
  background: #667eea;
  color: #fff;
}

/* xvshao 自定义: 让技能卡片半透明，避免遮挡背景 */
.skill-selection {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.skill-title {
  color: #fff;
}

.skill-button {
  background: rgba(255, 255, 255, 0.9);
}
