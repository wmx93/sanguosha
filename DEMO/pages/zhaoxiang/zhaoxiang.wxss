/* pages/zhaoxiang/zhaoxiang.wxss */
@import "../guanning/guanning.wxss";

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  position: relative;
}

.page-title {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.counter-card {
  margin-top: 30rpx;
  width: 100%;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 24rpx;
}

.counter-label {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.counter-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.count-btn {
  width: 96rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #667eea;
  font-size: 44rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.18);
}

.count-btn::after {
  border: none;
}

.count-number {
  min-width: 120rpx;
  text-align: center;
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.35);
}

.reset-btn {
  margin-top: 24rpx;
  width: 100% !important;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reset-btn::after {
  border: none;
}

/* 扶汉模块 */
.fuhan-container {
  margin-top: 26rpx;
  width: 100%;
}

.fuhan-main-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #667eea;
  font-size: 34rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fuhan-main-btn::after {
  border: none;
}

.fuhan-results {
  margin-top: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 24rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.results-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.results-reset {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  text-decoration: underline;
}

.result-item {
  margin-top: 16rpx;
}

.general-name {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.skill-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.skill-name-btn {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #667eea;
  font-size: 26rpx;
  font-weight: 700;
}

/* 已保留技能面板 */
.reserved-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 30rpx rgba(0, 0, 0, 0.18);
}

.reserved-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.reserved-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.reserved-reset {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.12);
}

.reserved-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.reserved-item {
  padding: 18rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reserved-item-main {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  min-width: 0;
}

.reserved-skill-name {
  color: #2b2b2b;
  font-size: 30rpx;
  font-weight: 900;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reserved-general {
  color: rgba(0, 0, 0, 0.55);
  font-size: 24rpx;
  font-weight: 700;
}

.reserved-tip {
  color: #667eea;
  font-size: 24rpx;
  font-weight: 800;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  z-index: 9999;
}

.modal-content {
  width: 100%;
  max-width: 620rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 26rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #333;
  text-align: center;
}

.modal-body {
  padding: 10rpx 26rpx 26rpx;
}

.selector-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 26rpx;
}

.selector-btn {
  width: 96rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: #667eea;
  color: #fff;
  font-size: 44rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-btn::after {
  border: none;
}

.selector-number {
  min-width: 140rpx;
  text-align: center;
  font-size: 56rpx;
  font-weight: 900;
  color: #333;
}

.selector-hint {
  margin-top: 14rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.modal-footer {
  padding: 0 26rpx 26rpx;
}

.modal-confirm-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 18rpx;
  background: #667eea;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-confirm-btn::after {
  border: none;
}