<!-- pages/zhaoxiang/zhaoxiang.wxml -->
<button class="back-btn" plain type="default" size="mini" bindtap="goBack" aria-label="返回" style="position: fixed; left: 24rpx; top: 85rpx">
  <text class="back-icon">‹</text>
</button>

<view class="container">
  <!-- 背景图片层 -->
  <view class="background-layer" wx:if="{{backgroundImage}}">
    <image class="background-image" src="{{backgroundImage}}" mode="aspectFill"></image>
    <view class="background-overlay"></view>
  </view>

  <view class="secondary-container">
    <view class="page-title">赵襄</view>

    <!-- 梅影标记功能 -->
    <view class="counter-card">
      <view class="counter-label">‘梅影’标记</view>
      <view class="counter-controls">
        <button class="count-btn" bindtap="decreaseMeiying">-</button>
        <text class="count-number">{{meiyingCount}}</text>
        <button class="count-btn" bindtap="increaseMeiying">+</button>
      </view>
      <button class="reset-btn" bindtap="resetMeiying">一键清零</button>
    </view>

    <!-- 扶汉功能 -->
    <view class="fuhan-container">
      <button class="fuhan-main-btn" bindtap="openFuhanModal">扶汉</button>

      <!-- 已保留技能（最多2个） -->
      <view class="reserved-panel" wx:if="{{reservedSkills.length}}">
        <view class="reserved-header">
          <text class="reserved-title">已保留技能（{{reservedSkills.length}}/2）</text>
          <text class="reserved-reset" bindtap="resetFuhan">重置</text>
        </view>
        <view class="reserved-list">
          <view
            class="reserved-item"
            wx:for="{{reservedSkills}}"
            wx:key="name"
            bindtap="onReservedSkillTap"
            data-skill="{{item}}"
          >
            <view class="reserved-item-main">
              <text class="reserved-skill-name">{{item.name}}</text>
              <text class="reserved-general">{{item.generalName}}</text>
            </view>
            <text class="reserved-tip">点击查看</text>
          </view>
        </view>
      </view>

      <!-- 抽取结果展示：武将名 + 技能名（点技能名看描述） -->
      <view class="fuhan-results" wx:if="{{fuhanResults.length && reservedSkills.length < 2}}">
        <view class="results-header">
          <text class="results-title">扶汉结果：</text>
          <text class="results-reset" bindtap="resetFuhan">重置</text>
        </view>

        <view class="result-list">
          <view class="result-item" wx:for="{{fuhanResults}}" wx:key="general">
            <text class="general-name">{{item.general}}</text>
            <view class="skill-list">
              <text
                class="skill-name-btn"
                wx:for="{{item.skills}}"
                wx:for-item="skill"
                wx:key="name"
                bindtap="onFuhanSkillTap"
                data-general="{{item.general}}"
                data-skill="{{skill}}"
              >{{skill.name}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 扶汉：武将数选择弹窗（- / +，最小 4） -->
<view class="modal-mask" wx:if="{{showFuhanModal}}" bindtap="closeFuhanModal">
  <view class="modal-content" catchtap="noop">
    <view class="modal-header">选择武将数</view>
    <view class="modal-body">
      <view class="selector-controls">
        <button class="selector-btn" bindtap="decreaseSelectCount">-</button>
        <text class="selector-number">{{selectGeneralCount}}</text>
        <button class="selector-btn" bindtap="increaseSelectCount">+</button>
      </view>
      <view class="selector-hint">至少选择 4 名武将</view>
    </view>
    <view class="modal-footer">
      <button class="modal-confirm-btn" bindtap="confirmFuhan">确定抽取</button>
    </view>
  </view>
</view>
